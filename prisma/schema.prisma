generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  actor
  caster
}

enum ImageType {
  left
  center
  right
}

enum ApplicationStatus {
  applied
  shortlisted
  selected
  rejected
}

enum VerificationStatus {
  unsubmitted
  pending
  verified
}

model User {
  id                  String          @id @default(cuid())
  role                UserRole
  fullName            String
  email               String          @unique
  passwordHash        String
  phone               String?
  avatarUrl           String?
  onboardingCompleted Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  actorProfile        ActorProfile?
  castingProfile      CastingProfile?
  notifications       Notification[]
}

model ActorProfile {
  id             String       @id @default(cuid())
  userId         String       @unique
  age            Int?
  gender         String?
  height         String?
  languages      String[]     @default([])
  location       String?
  bio            String?
  pastWorks      Json         @default("[]")
  onboardingStep Int          @default(1)
  isProfileReady Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  images         ActorImage[]
  applications   Application[]
}

model ActorImage {
  id        String       @id @default(cuid())
  actorId    String
  type      ImageType
  imageUrl  String
  createdAt DateTime     @default(now())
  actor     ActorProfile @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([actorId, type])
}

model CastingProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  companyName        String
  description        String?
  website            String?
  verified           Boolean            @default(false)
  verificationStatus VerificationStatus @default(unsubmitted)
  trustNote          String?
  onboardingStep     Int                @default(1)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  castingCalls       CastingCall[]
}

model CastingCall {
  id                   String        @id @default(cuid())
  casterId             String
  title                String
  description          String?
  requirements         Json          @default("{}")
  sampleScriptUrl      String?
  voiceNoteUrl         String?
  projectType          String?
  shootLocation        String?
  compensationDetails  String?
  auditionInstructions String?
  submissionChecklist  String[]      @default([])
  isActive             Boolean       @default(true)
  deadline             DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  castingProfile       CastingProfile @relation(fields: [casterId], references: [id], onDelete: Cascade)
  applications         Application[]
}

model Application {
  id               String            @id @default(cuid())
  castingCallId    String
  actorId          String
  auditionVideoUrl String?
  notes            String?
  reviewNotes      String?
  reviewedAt       DateTime?
  status           ApplicationStatus @default(applied)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  castingCall      CastingCall       @relation(fields: [castingCallId], references: [id], onDelete: Cascade)
  actorProfile     ActorProfile      @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([castingCallId, actorId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
